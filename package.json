{
  "name": "amutix",
  "version": "2.0.0",
  "description": "Local coordination layer for AI agent teams: shared backlog, roles, reservations, review state, journal, and prompt context",
  "type": "module",
  "keywords": [
    "amutix",
    "ai-agents",
    "multi-agent",
    "agent-coordination",
    "agent-teams",
    "coordination-layer",
    "backlog",
    "review-workflow",
    "pi-package",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/amutix/amutix.git"
  },
  "homepage": "https://github.com/amutix/amutix",
  "bugs": {
    "url": "https://github.com/amutix/amutix/issues"
  },
  "author": "rezabaram",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "core/",
    "pi/",
    "cli/",
    "roles/",
    "team-templates/",
    "benchmarks/",
    "README.md",
    "VISION.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "amutix": "./cli/index.js"
  },
  "scripts": {
    "test": "node --experimental-strip-types test/parse.mjs && node --experimental-strip-types --test test/flows.ts"
  },
  "pi": {
    "extensions": [
      "./pi/index.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
